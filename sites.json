  "picks": [
    {
      "date": "2026-03-15",
      "name": "Lusion",
      "url": "https://lusion.co",
      "cover": "https://images.unsplash.com/photo-1633356122102-3fe601e05bd2?w=1200&q=80",
      "tagline": {
        "zh": "伦敦实验性 WebGL 工作室，把浏览器变成游乐场",
        "en": "London-based experimental WebGL studio turning browsers into playgrounds"
      },
      "rex_take": {
        "zh": "Lusion 是那种让你怀疑自己是否还在用浏览器的网站。每个项目都在挑战 Web 的表现力边界——流体模拟、粒子系统、实时 3D，全部跑在 WebGL 上。他们证明了一件事：技术炫技和设计表达之间不一定有矛盾，关键是你有没有故事要讲。如果你觉得网页设计只剩下 SaaS 落地页和 Tailwind 模板，来这里洗洗眼。",
        "en": "Lusion is the kind of site that makes you question whether you're still in a browser. Every project pushes the boundaries of web expressiveness — fluid simulations, particle systems, real-time 3D, all running on WebGL. They prove that technical showmanship and design expression aren't mutually exclusive — the key is having a story to tell."
      },
      "tags": [
        "WebGL",
        "3D",
        "实验性",
        "交互"
      ],
      "category": "studio"
    },
    {
      "date": "2026-03-16",
      "name": "Linear",
      "url": "https://linear.app",
      "cover": "https://cdn.dribbble.com/userupload/43574996/file/still-6f2195b47f626192918540485276674c.png?resize=1600x1200",
      "tagline": {
        "zh": "重新定义项目管理的工程师审美产品",
        "en": "Project management reimagined with engineer aesthetics"
      },
      "rex_take": {
        "zh": "Linear 是那种让你用了就回不去 Jira 的产品。它的设计哲学很简单：把每一毫秒的交互延迟都当作 bug 来修。键盘快捷键覆盖所有操作，动效快到你几乎注意不到但去掉了会觉得少了什么。这就是「工程师审美」的最佳注解——不是没有设计，而是设计完全服务于速度和效率。每个做 B2B SaaS 的团队都应该来这里学一课：好的产品设计不是加特效，是消灭摩擦。",
        "en": "Linear is the kind of product that makes Jira feel like punishment. Its design philosophy is simple: treat every millisecond of interaction delay as a bug. Keyboard shortcuts cover everything, animations so fast you barely notice them but would miss if removed. The best footnote to engineer aesthetics — not designless, but design entirely serving speed and efficiency."
      },
      "tags": [
        "产品设计",
        "SaaS",
        "效率",
        "暗色"
      ],
      "category": "product"
    },
    {
      "date": "2026-03-17",
      "name": "Stripe Press",
      "url": "https://press.stripe.com",
      "cover": "https://mir-s3-cdn-cf.behance.net/project_modules/1400_webp/a4318a211282795.672053c82577c.jpg",
      "tagline": {
        "zh": "支付巨头的出版实验——科技公司也能做出最美的书",
        "en": "A payment giant's publishing experiment — proving tech companies can make the most beautiful books"
      },
      "rex_take": {
        "zh": "Stripe Press 的网站是我见过的最好的数字出版设计之一。每本书的展示页都是一个独立的设计作品——不是简单的封面+简介，而是用排版、配色、交互来传达每本书的气质。最让人佩服的是 Stripe 做这件事的动机：一家支付公司为什么要出版关于进步、城市规划、科学史的书？因为他们相信「思想基础设施」和「支付基础设施」一样重要。这个网站证明了一件事：品牌的边界不是产品本身，而是你的世界观有多大。",
        "en": "Stripe Press is one of the best digital publishing designs I've seen. Each book page is its own design piece — not just cover + blurb, but typography, color, and interaction conveying each book's character. Most impressive: why does a payment company publish books on progress, urbanism, science history? Because they believe intellectual infrastructure matters as much as payment infrastructure."
      },
      "tags": [
        "排版",
        "出版",
        "极简",
        "品牌"
      ],
      "category": "product"
    },
    {
      "date": "2026-03-18",
      "name": "Teenage Engineering",
      "url": "https://teenage.engineering",
      "cover": "https://cdn.dribbble.com/userupload/46797862/file/still-97001c2f52a5da46dea8ac17bf3afb6e.png",
      "tagline": {
        "zh": "瑞典硬件设计工作室——把合成器做成艺术品",
        "en": "Swedish hardware design studio — turning synthesizers into art objects"
      },
      "rex_take": {
        "zh": "Teenage Engineering 的网站和他们的产品一样：每一个像素都在说「我们不在乎行业惯例」。导航逻辑反直觉但用了就上瘾，产品图片的拍摄角度和布光堪比时尚大片，价格标注方式像在炫耀而非道歉。这是一家真正理解「设计即品牌」的公司——你不需要 logo 就能认出这是他们的东西。对所有做硬件产品的团队：来这里学学怎么让网站和产品拥有同一种灵魂。",
        "en": "Teenage Engineering's website is like their products: every pixel says \"we don't care about industry conventions.\" Navigation is counter-intuitive but addictive, product photography rivals fashion shoots, pricing is displayed like bragging not apologizing. A company that truly understands design IS brand."
      },
      "tags": [
        "产品",
        "工业设计",
        "极简",
        "硬件"
      ],
      "category": "brand"
    },
    {
      "date": "2026-03-19",
      "name": "Bruno Simon",
      "url": "https://bruno-simon.com",
      "cover": "https://cdn.dribbble.com/userupload/12417018/file/original-12d11249de49eeea19f0bbef59854dc2.png?resize=752x&vertical=center",
      "tagline": {
        "zh": "用 Three.js 小汽车逛个人简历——交互设计的天花板",
        "en": "Drive a Three.js car through your portfolio — the ceiling of interactive design"
      },
      "rex_take": {
        "zh": "Bruno Simon 的作品集大概是互联网上被分享最多的个人网站之一。你操控一辆 3D 小汽车在虚拟世界里探索他的简历和作品——听起来像噱头，但体验下来你会发现每一个交互细节都打磨到极致：物理引擎的手感、碰撞反馈、相机跟随的平滑度。这不是「炫技」，这是一个 Three.js 教育者用自己的网站做的最好的教学案例。它回答了一个老问题：创意开发者的作品集应该长什么样？答案是：它本身就应该是你最好的作品。",
        "en": "Bruno Simon's portfolio is probably one of the most shared personal sites on the internet. You drive a 3D car through a virtual world exploring his resume and work. Sounds gimmicky, but every interaction detail is polished to perfection: physics engine feel, collision feedback, camera follow smoothness. Not showing off — it's the best teaching case from a Three.js educator. It answers an old question: what should a creative developer's portfolio look like? Answer: it should BE your best work."
      },
      "tags": [
        "3D",
        "Three.js",
        "创意",
        "作品集"
      ],
      "category": "portfolio"
    }
